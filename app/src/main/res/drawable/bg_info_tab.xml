<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_selected="true">
        <shape android:shape="rectangle">
            <solid android:color="@color/tab_bg_active" />
            <stroke android:width="0.5dp" android:color="@color/tab_bg_active" />
            <corners android:radius="10dp" />
            <padding android:left="9dp" android:top="3dp" android:right="9dp" android:bottom="3dp" />
        </shape>
    </item>
    <item>
        <shape android:shape="rectangle">
            <solid android:color="@color/tab_bg_inactive" />
            <stroke android:width="0.5dp" android:color="@color/tab_border" />
            <corners android:radius="10dp" />
            <padding android:left="9dp" android:top="3dp" android:right="9dp" android:bottom="3dp" />
        </shape>
    </item>
</selector>
